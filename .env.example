# Target chain
QUIET_TILL_RPC_URL=https://example-skaletestnet-rpc.invalid
QUIET_TILL_CHAIN_ID=replace_with_chain_id

# Deployment signers
# Never commit real private keys. Use a throwaway funded key for hackathon testnet demos.
QUIET_TILL_ADMIN_PRIVATE_KEY=replace_with_32_byte_hex_private_key
QUIET_TILL_MERCHANT_OWNER_PRIVATE_KEY=replace_with_32_byte_hex_private_key

# Demo role addresses
QUIET_TILL_POS_AGENT_ADDRESS=0x0000000000000000000000000000000000000000
QUIET_TILL_AUDITOR_ADDRESS=0x0000000000000000000000000000000000000000
QUIET_TILL_LENDER_ADDRESS=0x0000000000000000000000000000000000000000
QUIET_TILL_DECRYPT_CALLBACK_ADDRESS=0x0000000000000000000000000000000000000000

# Set after deployment when preparing a live BITE ciphertext for CTX
QUIET_TILL_DAILY_SETTLEMENT_WINDOW_ADDRESS=0x0000000000000000000000000000000000000000

# Optional JSON output path for successful deployments
QUIET_TILL_DEPLOY_OUTPUT=deployments/quiet-till-demo.json
