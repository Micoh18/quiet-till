{
  "name": "quiet-till",
  "version": "0.1.0",
  "private": true,
  "description": "Private revenue settlement for onchain lending.",
  "type": "module",
  "scripts": {
    "build": "hardhat compile",
    "test": "hardhat test",
    "clean": "hardhat clean",
    "web:dev": "vite --host 127.0.0.1 --port 5173",
    "web:build": "vite build",
    "demo:manifest": "node scripts/demo-manifest.mjs",
    "demo:transcript": "node scripts/demo-transcript.mjs",
    "judge:evidence": "node scripts/judge-evidence.mjs",
    "report:prepare": "node scripts/prepare-private-report.mjs",
    "report:check": "node scripts/prepare-private-report.mjs --mock --quiet",
    "receipt:check": "node scripts/check-private-receipt.mjs",
    "payment:check": "node scripts/check-private-payment-commitment.mjs",
    "disclosure:check": "node scripts/check-auditor-disclosure-envelope.mjs",
    "auditor:export": "node scripts/auditor-receipt-export.mjs",
    "auditor:check": "node scripts/check-auditor-receipt-export.mjs",
    "skale:flow": "node scripts/run-skale-private-flow.mjs",
    "skale:check": "node scripts/run-skale-private-flow.mjs --dry-run --quiet",
    "demo:local": "npm run build && node scripts/run-local-demo.mjs",
    "deploy:demo": "npm run build && node scripts/deploy-demo.mjs",
    "deploy:check": "npm run build && node scripts/deploy-demo.mjs --dry-run --quiet",
    "demo:check": "npm run build && node scripts/check-demo-manifest.mjs",
    "privacy:check": "npm run build && node scripts/check-privacy-surface.mjs",
    "local:check": "node scripts/run-local-demo.mjs --quiet",
    "transcript:check": "node scripts/check-demo-transcript.mjs",
    "judge:check": "node scripts/check-judge-evidence.mjs",
    "verify": "npm test && npm run web:build && npm run demo:check && npm run report:check && npm run receipt:check && npm run payment:check && npm run disclosure:check && npm run auditor:check && npm run skale:check && npm run privacy:check && npm run deploy:check && npm run local:check && npm run transcript:check && npm run judge:check && npm audit --audit-level=high"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "hardhat": "^3.7.0",
    "typescript": "~6.0.3",
    "viem": "^2.52.0",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@skalenetwork/bite": "^0.8.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
