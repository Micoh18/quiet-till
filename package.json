{
  "name": "quiet-till",
  "version": "0.1.0",
  "private": true,
  "description": "Private revenue settlement for onchain lending.",
  "type": "module",
  "scripts": {
    "build": "hardhat compile",
    "test": "hardhat test",
    "clean": "hardhat clean",
    "web:dev": "vite --host 127.0.0.1 --port 5173",
    "web:build": "vite build",
    "demo:manifest": "node scripts/demo-manifest.mjs",
    "demo:transcript": "node scripts/demo-transcript.mjs",
    "demo:local": "npm run build && node scripts/run-local-demo.mjs",
    "demo:check": "npm run build && node scripts/check-demo-manifest.mjs",
    "local:check": "node scripts/run-local-demo.mjs --quiet",
    "transcript:check": "node scripts/check-demo-transcript.mjs",
    "verify": "npm test && npm run web:build && npm run demo:check && npm run local:check && npm run transcript:check && npm audit --audit-level=high"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "hardhat": "^3.7.0",
    "typescript": "~6.0.3",
    "viem": "^2.52.0",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
